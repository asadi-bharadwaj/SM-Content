# Copy this file to `.env` in the same folder and set real values.
# `.env` is gitignored — do not commit secrets.

# --- MongoDB (optional: overrides spring.data.mongodb.uri when you also set it in application.properties via this name) ---
# MONGODB_URI=mongodb+srv://user:pass@cluster.example.net/db?retryWrites=true&w=majority

# --- AWS (required when S3_BUCKET is set; otherwise uploads stay local) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

AWS_REGION=eu-north-1
S3_BUCKET=

# --- Optional: named profile instead of keys above (leave keys empty if using profile) ---
# AWS_PROFILE=default
